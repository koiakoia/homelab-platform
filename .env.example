# Infrastructure Configuration
# Copy this file to .env and fill in your values

# === Network ===
LAN_SUBNET=192.168.1            # Your LAN subnet prefix (e.g., 192.168.1)
GATEWAY_IP=192.168.1.1          # Default gateway
LAN_NETWORK=192.168.1.0         # LAN network address

# === Proxmox ===
PROXMOX_NODE1_IP=192.168.1.10   # First Proxmox node
PROXMOX_NODE2_IP=192.168.1.11   # Second Proxmox node (if multi-node)
PROXMOX_NODE3_IP=192.168.1.12   # Third Proxmox node (if multi-node)
PROXMOX_PASSWORD=                # Proxmox root password

# === Services ===
GITLAB_IP=192.168.1.20          # GitLab server
VAULT_IP=192.168.1.21           # HashiCorp Vault
WAZUH_IP=192.168.1.22           # Wazuh SIEM
PROXY_IP=192.168.1.23           # Reverse proxy (Pangolin/Traefik)
IAC_CONTROL_IP=192.168.1.24     # IaC control node
MINIO_PRIMARY_IP=192.168.1.25   # MinIO primary
MINIO_REPLICA_IP=192.168.1.26   # MinIO replica
SEEDBOX_IP=192.168.1.27         # Seedbox VM
FORGEJO_IP=192.168.1.28         # Forgejo (optional)

# === Domains ===
DOMAIN=example.com              # Your base domain
INTERNAL_DOMAIN=internal.example.com  # Internal services domain

# === OKD/OpenShift ===
OKD_CLUSTER=overwatch            # OKD cluster name
OKD_MASTER1_IP=10.0.0.221
OKD_MASTER2_IP=10.0.0.222
OKD_MASTER3_IP=10.0.0.223
OKD_BOOTSTRAP_IP=10.0.0.220
PXE_SERVER_IP=10.0.0.1
CONFIG_SERVER_IP=10.0.0.2

# === Auth ===
GITLAB_PAT=                      # GitLab personal access token
VAULT_TOKEN=                     # Vault root/admin token
GITLAB_USER=admin                # GitLab admin username
GITLAB_NAMESPACE=admin           # GitLab project namespace
USERNAME=admin                   # SSH/system username
SSH_KEY_COMMENT=user@host        # SSH key comment
